{
  "name": "open-watch-party",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:extension": "pnpm --filter @open-watch-party/extension dev",
    "dev:firefox": "pnpm --filter @open-watch-party/extension dev:firefox",
    "dev:server": "pnpm --filter @open-watch-party/server dev",
    "build": "pnpm --filter @open-watch-party/extension build",
    "build:firefox": "pnpm --filter @open-watch-party/extension build:firefox",
    "build:safari": "pnpm --filter @open-watch-party/extension build:safari",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "pnpm lint && pnpm format:check && pnpm --filter @open-watch-party/extension check && pnpm --filter @open-watch-party/shared test",
    "postinstall": "pnpm --filter @open-watch-party/extension exec wxt prepare"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
